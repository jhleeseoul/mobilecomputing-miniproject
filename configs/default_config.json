{
  "seed": 42,
  "sample_rate": 16000,
  "clip_duration_ms": 1000,
  "frame_length": 640,
  "frame_step": 320,
  "fft_length": 1024,
  "num_mel_bins": 40,
  "n_mfcc": 13,
  "feature_type": "mfcc",
  "normalize": true,
  "num_classes": 10,
  "commands": ["yes", "no", "up", "down", "left", "right", "stop", "go"],
  "unknown_ratio": 1.0,
  "silence_ratio": 0.1,
  "augment": {
    "enabled": true,
    "time_shift_ms": 100,
    "noise_prob": 0.8,
    "noise_level_min": 0.0,
    "noise_level_max": 0.2,
    "volume_min": 0.3,
    "volume_max": 1.6
  },
  "train": {
    "batch_size": 64,
    "epochs": 20,
    "learning_rate": 0.001,
    "early_stopping_patience": 5,
    "label_smoothing": 0.0,
    "steps_per_execution": 32,
    "fit_verbose": 2,
    "class_weights": {
      "yes": 1.0,
      "no": 1.0,
      "up": 1.0,
      "down": 1.25,
      "left": 1.0,
      "right": 1.0,
      "stop": 1.0,
      "go": 1.15,
      "unknown": 1.0,
      "silence": 1.0
    }
  },
  "quantization": {
    "representative_samples": 200,
    "target": "int8"
  },
  "data": {
    "use_feature_cache": true,
    "feature_cache_dir": "artifacts/data/feature_cache",
    "cache_train_augmented_features": false,
    "shuffle_buffer_size": 10000
  },
  "paths": {
    "dataset_root": "",
    "manifest": "artifacts/data/manifest.csv",
    "splits_dir": "artifacts/data/splits",
    "models_dir": "artifacts/models",
    "reports_dir": "artifacts/reports"
  }
}
